# Utility Scripts

## Framework Detection Script

```bash
#!/bin/bash
# detect_framework.sh

echo "Detecting framework..."

# Next.js
if [ -f "next.config.js" ] || [ -f "next.config.ts" ]; then
    echo "Next.js detected"
fi

# Laravel
if [ -f "artisan" ] && [ -f "composer.json" ]; then
    echo "Laravel detected"
fi

# Rails
if [ -f "config.ru" ] && [ -f "Gemfile" ]; then
    echo "Rails detected"
fi

# Django
if [ -f "manage.py" ]; then
    echo "Django detected"
fi

# React Native
if [ -f "App.tsx" ] && [ -f "app.json" ]; then
    echo "React Native detected"
fi

# Flutter
if [ -f "pubspec.yaml" ]; then
    echo "Flutter detected"
fi

# Go
if [ -f "go.mod" ]; then
    echo "Go detected"
fi

# Rust
if [ -f "Cargo.toml" ] && [ -f "src-tauri/tauri.conf.json" ]; then
    echo "Tauri detected"
elif [ -f "Cargo.toml" ]; then
    echo "Rust detected"
fi
```

## CLAUDE.md Section Validator

```python
#!/usr/bin/env python3
# validate_claude_md.py

import sys
import re

REQUIRED_SECTIONS = [
    "Core Identity",
    "Foundational Principles",
    "Implementation Standards",
    "Development Workflow",
    "Testing Strategy",
    "Code Quality",
    "Git & Version Control",
    "Error Handling",
]

def validate(file_path: str) -> tuple[int, list[str]]:
    with open(file_path) as f:
        content = f.read()

    errors = []
    for section in REQUIRED_SECTIONS:
        pattern = rf"##\s+{section}"
        if not re.search(pattern, content, re.IGNORECASE):
            errors.append(f"Missing section: {section}")

    return len(errors), errors

if __name__ == "__main__":
    path = sys.argv[1] if len(sys.argv) > 1 else "CLAUDE.md"
    errors, messages = validate(path)

    if errors == 0:
        print(f"✅ CLAUDE.md is valid ({len(REQUIRED_SECTIONS)}/15 sections present)")
    else:
        print(f"❌ CLAUDE.md has {errors} issues:")
        for msg in messages:
            print(f"  - {msg}")

    sys.exit(errors)
```

